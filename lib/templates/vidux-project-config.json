{
  "project": {
    "name": "Vidux Team Agent Project",
    "type": "vidux",
    "description": "Plan-first documentation template for repos coordinated through vidux PLAN.md files and team-agent lanes"
  },
  "ai": {
    "default_model": "sonnet",
    "fast_model": "sonnet",
    "default_mode": "interactive",
    "timeout_seconds": 90
  },
  "documentation": {
    "framework": "vitepress",
    "source_dir": "docs",
    "config_file": "docs/.vitepress/config.ts",
    "serve_port": 5173,
    "serve_command": "npm run docs:dev",
    "sidebar_structure_guide": {
      "_comment": "Vidux template: keep plan state, commands, agent lanes, and verification docs separate.",
      "/": [
        {
          "text": "Plan Surface",
          "items": [
            { "text": "Overview", "link": "/guide/" },
            { "text": "Plan Files", "link": "/reference/plans" },
            { "text": "Command Reference", "link": "/reference/commands" }
          ]
        },
        {
          "text": "Team Agents",
          "items": [
            { "text": "Agent Lanes", "link": "/agents/" },
            { "text": "Handoffs", "link": "/agents/handoffs" },
            { "text": "Drift Logs", "link": "/agents/drift" }
          ]
        },
        {
          "text": "Operations",
          "items": [
            { "text": "Verification", "link": "/operations/verification" },
            { "text": "Telemetry", "link": "/operations/telemetry" },
            { "text": "Troubleshooting", "link": "/troubleshooting" }
          ]
        }
      ]
    }
  },
  "files": {
    "instructions": "README.md",
    "main_config": "vidux.config.json",
    "source_dir": "scripts"
  },
  "features": {
    "testing": {
      "enabled": true,
      "framework": "repo-defined"
    },
    "team_agents": {
      "enabled": true,
      "plan_files": ["PLAN.md", "projects/*/PLAN.md"],
      "local_state": [".claudux-state.json", ".claudux/index/", ".vidux/"]
    }
  },
  "claude_instructions": {
    "focus_areas": [
      "PLAN.md and projects/*/PLAN.md as source-owned operating state",
      "Team-agent lane handoffs, ownership, and verification gates",
      "Command references for bin/ scripts and checked-in shell helpers",
      "Drift Log and Progress sections as append-only evidence, not marketing copy",
      "docs-structure.json manifest ownership when deterministic docs mode is enabled",
      "Local telemetry, cache, and state files only when they are checked in or documented as local-only"
    ]
  }
}
