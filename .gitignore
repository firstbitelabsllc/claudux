# Documentation (commit the docs site so Pages can build)
# If you want to keep docs untracked locally, use a personal excludes file instead.
# .git/info/exclude → docs/

# Ignore docs build artifacts and local deps
docs/.vitepress/cache/
docs/.vitepress/dist/
docs/node_modules/

# Node modules (if VitePress is installed locally)
node_modules/

# VitePress cache
.vitepress/cache/
.vitepress/dist/

# macOS
.DS_Store

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Site plan (generated)
docs-site-plan.json

# Local docs and release notes (do not publish)
documents/.cursorrules

# Editor and tooling
.cursorrules
documents/
.npmrc

# Secrets / environment
.env
.env.*
*.key
*.pem
secrets/

# claudux change tracking state (local per-dev)
.claudux-state.json
.claudux/index/

# docs-drift-lock.json is the committed drift baseline (the package-lock.json of
# doc/code drift). It is intentionally tracked so `claudux drift` has a baseline
# on a fresh CI checkout. Do not ignore it.
!docs-drift-lock.json
